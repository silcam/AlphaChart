{
  "name": "alphachart-server",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client"
  ],
  "dependencies": {
    "@types/cookie-session": "^2.0.37",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfkit": "^0.13.0",
    "@types/supertest": "^6.0.0",
    "body-parser": "^1.20",
    "cookie-session": "^2.1.0",
    "express": "^4.22.1",
    "express-fileupload": "^1.5.0",
    "immutability-helper": "^3.1.1",
    "memfs": "^4.x",
    "migrate": "^1.8.0",
    "mongodb": "^6.0.0",
    "nodemailer": "^8.0.4",
    "nodemailer-stub": "^1.2.1",
    "pdfkit": "^0.15.0",
    "puppeteer": "^24.x",
    "signal-exit": "^4.1.0",
    "supertest": "^7.0.0",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "start": "concurrently -p \"[{name}]\" -n \"TS,Server,Client\"  -c yellow,green,magenta \"tsc -w\" \"yarn start-server\" \"yarn start-client\"",
    "start-server": "nodemon server/dist/server/src/server.js --watch server/dist/ --delay 2",
    "start-client": "node start-client.js",
    "test": "NODE_ENV=test vitest",
    "coverage": "NODE_ENV=test vitest --coverage",
    "start-test": "yarn reset-cypress-images && NODE_ENV=test-cypress yarn start",
    "deploy": "bundle exec cap production deploy",
    "reset-cypress-images": "node reset-cypress-images.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.0.0",
    "cypress": "^13.15.0",
    "cypress-file-upload": "^5.0.0",
    "nodemon": "^3.1.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "yarn@4.13.0"
}
